---
import { IoIosArrowRoundBack } from 'react-icons/io';

import Layout from '@/layouts/layout.astro';
import Spacer from '@/components/spacer.astro';
import { ShinyText } from '@/components/shiny-text';

const conditions = [
  'care deeply about craft',
  'build real products and interfaces',
  'move comfortably between design and code',
  'have a portfolio showcasing their work',
  'are looking for exceptional opportunities',
];

const not = [
  'don’t have a portfolio showcasing your work',
  'are primarily focused on design or engineering alone',
  'are still building your first projects',
];
---

<Layout title="Talent Network">
  <div class="container">
    <section class="hero">
      <a href="/"><IoIosArrowRoundBack /></a>
      <h1>
        The <i>Design</i> Engineer<br /><i><ShinyText text="Talent" /></i> Network.
      </h1>
    </section>
    <main>
      <section class="description">
        <p>
          A curated talent network for design engineers who want access to the
          best opportunities in modern product teams.
        </p>

        <p>
          Every member is hand-picked to maintain a high-quality network of
          design engineers working at the intersection of design and code.
        </p>

        <p>
          Curated by <a
            href="https://x.com/remvze"
            rel="noreferrer"
            target="_blank">Maze Heart</a
          >.
        </p>
      </section>

      <Spacer />

      <section class="who">
        <h2>Who should apply</h2>
        <p>Design engineers who:</p>
        <ul>
          {conditions.map(condition => <li>{condition}</li>)}
        </ul>
      </section>

      <Spacer />

      <section class="not">
        <h2>Who this is not for</h2>
        <p>This network may not be the right fit if you:</p>
        <ul>
          {not.map(condition => <li>{condition}</li>)}
        </ul>
      </section>

      <section class="apply">
        <a
          href="https://app.decimals.co/profile/fbb614f5-a241-4ae8-8334-039427f078a4/apply"
          rel="noreferrer"
          target="_blank">Apply to Join</a
        >
      </section>
    </main>
  </div>
</Layout>

<style>
  .container {
    width: 90%;
    max-width: 500px;
    margin: 0 auto;
  }

  .hero {
    padding: 120px 0 60px;

    & a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      margin-bottom: 32px;
      color: var(--color-foreground);
      text-decoration: none;
      background: var(--color-neutral-100);
      border: 1px solid var(--color-neutral-200);
      border-radius: 50%;
    }

    & h1 {
      font-family: var(--font-display);
      font-size: var(--font-2xlg);
      line-height: 1.2;

      & i {
        font-style: italic;
      }
    }
  }

  .description {
    margin-bottom: 32px;

    & p {
      line-height: 1.6;
      color: var(--color-foreground-subtle);

      &:not(:last-of-type) {
        margin-bottom: 16px;
      }

      & a {
        font-weight: 500;
        color: var(--color-foreground);
        text-decoration: none;
      }
    }
  }

  .who,
  .not {
    margin: 32px 0;

    & h2 {
      margin-bottom: 16px;
      font-weight: 500;
      color: var(--color-foreground);
    }

    & p {
      line-height: 1.6;
      color: var(--color-foreground-subtle);
    }

    & ul {
      margin-top: 8px;
      list-style-position: inside;

      & li {
        line-height: 1.6;

        &:not(:last-of-type) {
          margin-bottom: 4px;
        }

        &::marker {
          color: var(--color-foreground-subtler);
        }
      }
    }
  }

  .who {
    & ul li::marker {
      color: #34d399;
    }
  }

  .not {
    & ul li::marker {
      color: #fb7185;
    }
  }

  .apply {
    padding-bottom: 120px;
    margin-top: 48px;

    & a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 24px;
      font-size: var(--font-xsm);
      font-weight: 500;
      color: var(--color-neutral-50);
      text-decoration: none;
      background: var(--color-neutral-900);
      border-radius: 999px;
      box-shadow: inset 0 -3px 0 rgb(0 0 0 / 20%);
      transition: 0.2s;

      &:hover {
        background: var(--color-neutral-800);
      }
    }
  }
</style>
